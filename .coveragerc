[run]
source          = .
omit            =
    tests/*
    .venv/*
    venv/*
    */site-packages/*
    */__pycache__/*
    setup.py
    conftest.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if TYPE_CHECKING:
    raise NotImplementedError
    if __name__ == .__main__.:
    pass
show_missing = true
skip_covered = false

[html]
directory = htmlcov
